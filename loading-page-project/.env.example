# Google Maps API Configuration
# ════════════════════════════════════════════════════════════════
# HƯỚNG DẪN: Rename file này thành '.env' và thêm API key của bạn

# Google Maps Distance Matrix API Key
# Lấy từ: https://console.cloud.google.com
GOOGLE_MAPS_API_KEY=YOUR_API_KEY_HERE

# Ví dụ (đừng dùng key này, nó là fake):
# GOOGLE_MAPS_API_KEY=AIzaSyDxxxxxxxxxxxxxxxxxxxxxxxxxxx
